<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CreteLab - Betonrezept Rechner</title>
    <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🏗️ CreteLab</h1>
            <p class="tagline">Ihr intelligenter Betonrezept Rechner nach Zement-Merkblatt B 20</p>
        </header>

        <main id="calculator">
            <section class="form-section">
                <h2>Betoneigenschaften</h2>
                
                <div class="form-group">
                    <label for="useCase">Verwendungszweck:</label>
                    <select id="useCase" name="useCase">
                        <!-- Options will be populated dynamically -->
                    </select>
                    <small class="form-hint" id="useCaseHint">Wählen Sie einen Anwendungsfall, um vorgeschlagene Parameter zu laden.</small>
                </div>

                <div class="form-group">
                    <label for="volume">Benötigtes Volumen (m³):</label>
                    <input type="number" id="volume" name="volume" step="0.1" min="0.1" value="1" placeholder="z.B. 0.5">
                </div>

                <div class="form-group">
                    <label for="strengthClass">Druckfestigkeitsklasse:</label>
                    <select id="strengthClass" name="strengthClass">
                        <!-- Options will be populated dynamically -->
                    </select>
                    <small class="form-hint" id="strengthHint">Wählen Sie eine Klasse gemäß statischen Anforderungen und Nutzung.</small>
                </div>

                <div class="form-group">
                    <label>Umgebungseinwirkung (Mehrfachauswahl möglich):</label>
                    <div class="checkbox-grid" id="exposureClassContainer">
                        <!-- Options will be populated dynamically -->
                    </div>
                    <small class="form-hint">Wählen Sie alle in Ihrem Objekt relevanten Expositionsklassen; die restriktivste (“maßgeblich”) wird zur Berechnung genutzt.</small>
                </div>

                <h3>Zusätzliche Parameter (optional)</h3>

                <div class="form-group">
                    <label for="siebline">Sieblinie der Gesteinskörnung:</label>
                    <select id="siebline" name="siebline">
                        <!-- Options will be populated dynamically -->
                    </select>
                    <small class="form-hint" id="sieblinieHint">Feinere Sieblinien benötigen mehr Wasser, gröbere Sieblinien sparen Wasser.</small>
                </div>

                <div class="form-group">
                    <label for="consistencyClass">Konsistenzklasse:</label>
                    <select id="consistencyClass" name="consistencyClass">
                        <!-- Options will be populated dynamically -->
                    </select>
                </div>

                <div class="form-group">
                    <label for="aggregateType">Gesteinskörnung:</label>
                    <select id="aggregateType" name="aggregateType">
                        <!-- Options will be populated dynamically -->
                    </select>
                </div>

                <h3>Zusatzstoffe (optional)</h3>

                <!-- Betonverflüssiger / Fließmittel -->
                <div class="form-group">
                    <label for="admixtureType">Verflüssigungsmittel:</label>
                    <select id="admixtureType" name="admixtureType">
                        <!-- Options will be populated dynamically -->
                    </select>
                    <small class="form-hint" id="admixtureHint">Kein Zusatzmittel verwendet</small>
                </div>

                <!-- Luftporenbildner -->
                <div class="form-group">
                    <label for="useAirEntraining">
                        <input type="checkbox" id="useAirEntraining" name="useAirEntraining" style="width: auto; margin-right: 8px;">
                        Luftporenbildner verwenden (für Frostsicherheit)
                    </label>
                </div>

                <div class="form-group" id="airEntrainingContainer" style="display: none;">
                    <label for="airEntrainingPercent">Luftgehalt (% Vol.-%):</label>
                    <input type="number" id="airEntrainingPercent" name="airEntrainingPercent" step="0.5" min="1.5" max="6" value="4">
                    <small class="form-hint">Empfohlen für frostbelastete Bauteile (z.B. Außenbereiche). 1% LP ≈ 5l weniger Wasser, aber ca. 3.5 N/mm² geringere Festigkeit.</small>
                </div>

                <!-- Flugasche -->
                <div class="form-group">
                    <label for="useFlyAsh">
                        <input type="checkbox" id="useFlyAsh" name="useFlyAsh" style="width: auto; margin-right: 8px;">
                        Flugasche (k=0.4) verwenden
                    </label